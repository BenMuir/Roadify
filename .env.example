# Copy this file to .env and adjust.

# Set to 1 to run locally WITHOUT Azure Cosmos DB (incidents kept in RAM until you stop the server).
# You do not install Cosmos on your machine — it is a cloud service; use this if you have no Cosmos account yet.
DEV_WITHOUT_COSMOS=1

# If DEV_WITHOUT_COSMOS is unset or 0, these are required (Azure Portal → Cosmos DB → Keys):
# COSMOS_CONNECTION_STRING=AccountEndpoint=https://....documents.azure.com:443/;AccountKey=...;
# COSMOS_DATABASE_ID=your-database-id
# COSMOS_CONTAINER_ID=your-container-id

# Optional; defaults to 3000 if unset
PORT=3000

# Blob uploads (GET /get-upload-token)
# AZURE_STORAGE_CONTAINER_NAME=your-blob-container-name
